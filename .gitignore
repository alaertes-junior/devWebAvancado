## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.
##
## This .gitignore file can be used for any Visual Studio solution,
## and it's based on the official GitHub Visual Studio .gitignore.

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio 2015/2017/2019/2022 cache and settings
.vs/
# Uncomment if you have tasks that create the .user file
# *.user
# *.userosscache
# *.sln.docstates

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Mono auto generated files
mono_crash.*

# Windows image-cache files
Thumbs.db
ehthumbs.db

# Folder config file
Desktop.ini

# Recycled bin used on internal and external drives
$RECYCLE.BIN/

# VS Code files
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# .NET Core / .NET files
project.lock.json
project.fragment.lock.json
artifacts/

# ASP.NET Core
wwwroot/lib/
# ASP.NET Core secrets json file
appsettings.Development.json

# Entity Framework
*.db
*.db-shm
*.db-wal

# Rider
.idea/
*.sln.iml

*.claude
